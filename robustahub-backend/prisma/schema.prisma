generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================
// 1. TABEL PENGGUNA (USER)
// ==============================
model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      RoleUser   @default(COFFEE_SHOP)
  
  // Kontak & Profil
  phone     String?
  address   String?    @db.Text
  shopName  String?  
  
  // Data Rekening (Khusus Petani untuk pencairan Xendit)
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  
  // Relasi
  products  Product[]  // Petani memiliki banyak produk
  orders    Order[]    // Coffee shop memiliki banyak pesanan

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum RoleUser {
  PETANI
  COFFEE_SHOP
  ADMIN
}

// ==============================
// 2. TABEL KATALOG KOPI (PRODUCT)
// ==============================
model Product {
  id               String         @id @default(uuid())
  name             String
  description      String?        @db.Text
  price            Int            // Harga per KG
  stock            Int            // Stok dalam KG
  minOrder         Int            @default(5) // Minimal pembelian B2B (default 5kg)
  
  // Kategori & Media
  category         CategoryCoffee
  imageUrl         String?        // URL dari multer/cloudinary
  
  // Spesifikasi Teknis (Untuk B2B)
  tastingNotes     String?
  processingMethod String?        @default("Natural Process")
  elevation        String?        @default("600 - 800 mdpl")
  defectRate       String?        @default("< 5%")
  
  isActive         Boolean        @default(true) // Untuk hide/show etalase
  
  // Relasi ke Petani
  petaniId         String
  petani           User           @relation(fields: [petaniId], references: [id])
  orderItems       OrderItem[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum CategoryCoffee {
  ROBUSTA
  ARABIKA
  HOUSE_BLEND
}

// ==============================
// 3. TABEL PESANAN UTAMA (ORDER)
// ==============================
model Order {
  id          String      @id @default(uuid())
  totalAmount Int
  status      OrderStatus @default(PENDING)
  
  // Relasi ke Pembeli (Coffee Shop)
  buyerId     String
  buyer       User        @relation(fields: [buyerId], references: [id])
  
  // Relasi ke tabel lain
  items       OrderItem[]
  payment     Payment?    // 1 Order punya 1 Pembayaran
  shipment    Shipment?   // 1 Order punya 1 Pengiriman

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING  // Petani sedang mengemas
  SHIPPED     // Petani sudah input resi
  COMPLETED
  CANCELLED
}

// ==============================
// 4. TABEL DETAIL BARANG (ORDER ITEM)
// ==============================
model OrderItem {
  id         String   @id @default(uuid())
  quantity   Int
  priceAtBuy Int      // Harga kopi saat dibeli (mencegah harga berubah di nota)
  
  // Relasi
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
}

// ==============================
// 5. TABEL PEMBAYARAN (PAYMENT)
// ==============================
model Payment {
  id               String        @id @default(uuid())
  amount           Int
  xenditInvoiceId  String?       @unique // Diubah dari midtransTransId
  paymentUrl       String?       // Link invoice Xendit untuk diklik pembeli
  paymentType      String?       // e.g., BANK_TRANSFER, E_WALLET
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?
  
  // Relasi 1-to-1 dengan Order
  orderId          String        @unique
  order            Order         @relation(fields: [orderId], references: [id])

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

// ==============================
// 6. TABEL PENGIRIMAN (SHIPMENT)
// ==============================
model Shipment {
  id              String         @id @default(uuid())
  shippingCost    Int
  waybillNumber   String?        // Nomor Resi yang diinput Petani
  courierName     String         // e.g., "Dakota Cargo"
  status          ShipmentStatus @default(PENDING)
  
  // Relasi 1-to-1 dengan Order
  orderId         String         @unique
  order           Order          @relation(fields: [orderId], references: [id])

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
}